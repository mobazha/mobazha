# Mobazha Standalone Store — Caddyfile (generated by CaddyManager)
# DO NOT EDIT — regenerated on domain/overlay config changes.
{{- if eq .Connectivity "overlay" }}

{
	auto_https off
}
{{- end }}

{{- if .Domain }}
{{ .Domain }} {
{{- else }}
:443 {
{{- end }}
{{- if eq .Connectivity "overlay" }}
	tls internal
{{- end }}
	encode gzip

	# Buyer API proxy: strip /buyer-api prefix, forward to SaaS
	handle /buyer-api/* {
		uri strip_prefix /buyer-api
		reverse_proxy {{ .SaaSAPIURL }} {
			header_up Host {http.reverse_proxy.upstream.hostport}
			header_up X-Standalone-Store-Key {{ .APIKey }}
		}
	}

	# Node API
	handle /v1/* {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# Admin routes
	handle /admin/* {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# Health check (unauthenticated)
	handle /healthz {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# WebSocket
	handle /ws {
		reverse_proxy localhost:{{ .NodePort }}
	}
	handle /ws/* {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# SSR: meta injection for crawlers + embed cards
	handle /product/* {
		reverse_proxy localhost:{{ .NodePort }}
	}
	handle /store/* {
		reverse_proxy localhost:{{ .NodePort }}
	}
	handle /embed/* {
		reverse_proxy localhost:{{ .NodePort }}
	}
	handle /api/oembed {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# Frontend SPA
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
