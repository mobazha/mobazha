#!/bin/sh
set -e

echo "=== init-data: Initializing standalone store ==="

mkdir -p /data

# Generate Caddyfile from template
/usr/local/bin/generate-caddyfile

# If ADMIN_PASSWORD env var is set and no hash file exists, use it as initial password
if [ -n "$ADMIN_PASSWORD" ] && [ ! -f /data/admin_password_hash ]; then
    echo "$ADMIN_PASSWORD" > /data/admin_password
    chmod 600 /data/admin_password
    echo "init-data: Admin password set from environment"
fi

# Inject runtime config into frontend SPA.
# The Vite build uses compile-time env vars, but SAAS_API_URL is only known
# at container startup. This script generates a JS file that the SPA reads
# before initializing, allowing runtime override of the SaaS URL.
RUNTIME_JS="/srv/www/runtime-config.js"
SAAS_URL="${SAAS_API_URL:-}"
cat > "$RUNTIME_JS" <<JSEOF
window.__RUNTIME_CONFIG__={saasUrl:"${SAAS_URL}"};
JSEOF
echo "init-data: Runtime config written (saasUrl=${SAAS_URL:-(empty)})"

echo "=== init-data: Complete ==="
