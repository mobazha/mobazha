# Mobazha Standalone Store — Caddyfile (generated by CaddyManager)
# DO NOT EDIT — regenerated on domain/overlay config changes.
{{- if eq .Connectivity "overlay" }}

{
	auto_https off
}
{{- end }}

{{- if .Domain }}
{{ .Domain }} {
{{- else }}
:443 {
{{- end }}
{{- if eq .Connectivity "overlay" }}
	tls internal
{{- end }}
	encode gzip

	# Buyer API proxy: strip /buyer-api prefix, forward to SaaS
	handle /buyer-api/* {
		uri strip_prefix /buyer-api
		reverse_proxy {{ .SaaSAPIURL }} {
			header_up Host {http.reverse_proxy.upstream.hostport}
			header_up X-Standalone-Store-Key {{ .APIKey }}
		}
	}

	# Runtime bootstrap is generated dynamically by the node.
	handle /runtime-config.js {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# Node API
	handle /v1/* {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# Admin routes
	handle /admin/* {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# Health check (unauthenticated)
	handle /healthz {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# WebSocket
	handle /ws {
		reverse_proxy localhost:{{ .NodePort }}
	}
	handle /ws/* {
		reverse_proxy localhost:{{ .NodePort }}
	}

	# Next.js static assets (immutable, aggressive cache)
	# Monorepo standalone: static is at apps/web/.next/static/
	handle /_next/static/* {
		root * /app/frontend/apps/web/.next
		uri strip_prefix /_next
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# All other requests: Next.js SSR server
	handle {
		reverse_proxy localhost:{{ .NextJSPort }}
	}
}
