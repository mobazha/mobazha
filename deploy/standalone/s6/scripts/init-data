#!/bin/sh
set -e

echo "=== init-data: Initializing standalone store ==="

mkdir -p /data

# Generate Caddyfile from template
/usr/local/bin/generate-caddyfile

# If ADMIN_PASSWORD env var is set and no hash file exists, use it as initial password
if [ -n "$ADMIN_PASSWORD" ] && [ ! -f /data/admin_password_hash ]; then
    echo "$ADMIN_PASSWORD" > /data/admin_password
    chmod 600 /data/admin_password
    echo "init-data: Admin password set from environment"
fi

# Inject runtime config into Next.js public directory.
# NEXT_PUBLIC_* env vars are baked at build time, but SAAS_API_URL is only
# known at container startup. This generates a JS file that the frontend reads
# via window.__RUNTIME_CONFIG__ before initializing.
# Monorepo standalone: public/ is at apps/web/public/
RUNTIME_JS="/app/frontend/apps/web/public/runtime-config.js"
SAAS_URL="${SAAS_API_URL:-}"
cat > "$RUNTIME_JS" <<JSEOF
window.__RUNTIME_CONFIG__={saasUrl:"${SAAS_URL}",authMode:"standalone"};
JSEOF
echo "init-data: Runtime config written (saasUrl=${SAAS_URL:-(empty)}, authMode=standalone)"

echo "=== init-data: Complete ==="
