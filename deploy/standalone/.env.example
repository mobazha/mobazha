# Mobazha Standalone Store Configuration
#
# Copy this file to .env and edit the values.

# Your domain name (leave empty for IP-only mode with self-signed TLS)
STORE_DOMAIN=

# SaaS API URL for buyer identity and operations
SAAS_API_URL=https://app.mobazha.org

# API Key for authenticating with SaaS (generated by install.sh or manually)
STANDALONE_API_KEY=

# Initial admin password (optional — if empty, a random one is generated and printed to logs)
ADMIN_PASSWORD=

# SaaS default node peer ID (enables remote management via SaaS proxy for NAT'd stores)
# Get this value from the SaaS platform documentation.
SAAS_PEER_ID=

# Connectivity mode: public (has domain), tunnel (Cloudflare Tunnel), nat (libp2p only)
CONNECTIVITY=nat

# TLS mode for origin certificate:
#   internal — self-signed cert, use when behind Cloudflare or any L7 proxy (default)
#   acme     — Let's Encrypt auto-cert, use when domain points directly to this server
TLS_MODE=internal

# Overlay network type: lokinet or tor (leave empty for standard deployment)
# When set, use docker-compose.overlay.yml alongside docker-compose.yml
OVERLAY_TYPE=

# Overlay domain (e.g., your .loki or .onion address — auto-detected if empty)
OVERLAY_DOMAIN=

# Docker image tag (stable, beta, or edge)
TAG=stable

# Use cryptocurrency testnets (true = test coins, no real money)
TESTNET=
