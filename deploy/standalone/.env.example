# Mobazha Standalone Store Configuration
#
# Copy this file to .env and edit the values.

# Your domain name (leave empty for IP-only mode with self-signed TLS)
STORE_DOMAIN=

# SaaS API URL for buyer identity and operations
SAAS_API_URL=https://store.mobazha.org

# API Key for authenticating with SaaS (generated by install.sh or manually)
STANDALONE_API_KEY=

# Initial admin password (optional — if empty, a random one is generated and printed to logs)
ADMIN_PASSWORD=

# SaaS default node peer ID (enables remote management via SaaS proxy for NAT'd stores)
# Get this value from the SaaS platform documentation.
SAAS_PEER_ID=

# Connectivity mode: public (has domain), tunnel (Cloudflare Tunnel), nat (libp2p only)
CONNECTIVITY=nat

# Docker image tag (stable, beta, or edge)
TAG=stable
